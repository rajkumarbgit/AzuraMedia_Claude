# Local dev: docker-compose postgres. Production: Supabase connection string (use the pooled "Transaction" URI from Supabase > Settings > Database)
DATABASE_URL="postgresql://azuramedia:azuramedia@localhost:5432/azuramedia?schema=public"
# Supabase direct (non-pooled) URL, used by Prisma migrate
DIRECT_URL="postgresql://azuramedia:azuramedia@localhost:5432/azuramedia?schema=public"

NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
