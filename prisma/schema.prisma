generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum Role {
  CEO
  ADMIN
  PROJECT_MANAGER
  PRODUCTION_LEAD
  OPS
  CLIENT
  // Tagged to one or more clients; sees the client portal scoped to those clients only.
  ONSITE_MANAGER
}

enum Currency {
  USD
  EUR
  GBP
  INR
  AED
  SGD
  AUD
  JPY
  CNY
}

enum JobStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum MandateStatus {
  ACTIVE
  REMOVED
  PENDING
}

enum ApprovalType {
  MANDATE_ADD
  MANDATE_REDUCE
  JOB_AMEND
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

// Per-assignment work clock state (one ops/lead/pm person's personal progress on a task).
enum WorkStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  QUERY
  COMPLETED
}

enum TimeLogAction {
  START
  HOLD
  QUERY
  RESUME
  COMPLETE
}

enum ShiftCode {
  APAC
  EMEA
  AMER
  GEN
}

// ---------- Core people / org ----------

model Designation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  isActive      Boolean  @default(true)
  defaultShift  ShiftCode @default(GEN)
  // Set only for role = CLIENT: which client account this login belongs to.
  clientId      String?
  client        Client?  @relation("ClientUsers", fields: [clientId], references: [id])
  // Presence: updated by a lightweight heartbeat ping while the app is open.
  lastSeenAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobsCreated        Job[]            @relation("JobCreatedBy")
  approvalsRequested ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalsReviewed  ApprovalRequest[] @relation("ApprovalReviewedBy")
  timelineEvents     TimelineEvent[]  @relation("TimelineActor")
  leadOfTasks        Task[]           @relation("TaskLead")
  assignments        TaskAssignment[]
  leaves             Leave[]          @relation("LeaveOwner")
  leavesMarkedBy     Leave[]          @relation("LeaveMarkedBy")
  eodComments        EodComment[]
  breaks             BreakLog[]
  jobComments        JobComment[]     @relation("JobCommentAuthor")
  timeLogs           TimeLog[]        @relation("TimeLogActor")
  managedClients     ManagedClient[]
}

model Client {
  id           String   @id @default(cuid())
  name         String
  // Short uniform code used to auto-generate job numbers, e.g. "NIM", "SOL".
  code         String   @unique
  contactName  String?
  contactEmail String?
  currency     Currency @default(USD)
  // Running counter for this client's auto job numbering (CODE-0001, CODE-0002, ...).
  jobSeq       Int      @default(0)
  createdAt    DateTime @default(now())
  jobs         Job[]
  users        User[]   @relation("ClientUsers")
  managedBy    ManagedClient[]
}

// Tags a role = ONSITE_MANAGER user to one or more clients; they can view the client portal
// scoped to exactly these clients (a CLIENT-role login is tied to a single client instead).
model ManagedClient {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, clientId])
}

// ---------- Page-level permissions ----------

model Page {
  id    String @id @default(cuid())
  key   String @unique
  label String
  permissions RolePagePermission[]
}

model RolePagePermission {
  id        String  @id @default(cuid())
  role      Role
  pageId    String
  page      Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  canAccess Boolean @default(false)

  @@unique([role, pageId])
}

// ---------- Jobs / Mandates / Approvals / Timeline ----------

model Job {
  id                      String    @id @default(cuid())
  jobNo                   String    @unique
  title                   String
  clientId                String
  client                  Client    @relation(fields: [clientId], references: [id])
  currency                Currency  @default(USD)
  clientBudget            Decimal   @db.Decimal(14, 2)
  productionSpendPercent  Float
  pmComment               String?   @db.Text
  status                  JobStatus @default(DRAFT)
  version                 Int       @default(1)
  createdById             String
  createdBy               User      @relation("JobCreatedBy", fields: [createdById], references: [id])
  estimatedHours          Float?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  mandates       Mandate[]
  approvals      ApprovalRequest[]
  timelineEvents TimelineEvent[]
  tasks          Task[]
  comments       JobComment[]
}

model Mandate {
  id          String        @id @default(cuid())
  jobId       String
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // Cost added to the job's client budget by this mandate (if any) — surfaced to the client
  // as the cost impact of the approval request.
  addedCost   Decimal?      @db.Decimal(14, 2)
  status      MandateStatus @default(ACTIVE)
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ApprovalRequest {
  id              String         @id @default(cuid())
  jobId           String
  job             Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type            ApprovalType
  comment         String?        @db.Text
  payload         Json
  status          ApprovalStatus @default(PENDING)
  requestedById   String
  requestedBy     User           @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  // For MANDATE_ADD this is filled by the CLIENT user who approves/rejects (cost-increase requests
  // are routed to the client instead of an internal manager). Other types are reviewed internally.
  reviewedById    String?
  reviewedBy      User?          @relation("ApprovalReviewedBy", fields: [reviewedById], references: [id])
  reviewComment   String?        @db.Text
  // Snapshot of cost impact shown to the client at review time (e.g. { addedAmount, newTotal, currency }).
  costImpact      Json?
  createdAt       DateTime       @default(now())
  reviewedAt      DateTime?
}

model TimelineEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      String
  description String @db.Text
  version   Int
  actorId   String?
  actor     User?    @relation("TimelineActor", fields: [actorId], references: [id])
  meta      Json?
  createdAt DateTime @default(now())
}

// PM/Lead commentary on a job, typically added once a task/job is completed. Distinct from the
// per-person daily EodComment below — this is a job-level note for the client/roadmap view.
model JobComment {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  authorId  String
  author    User     @relation("JobCommentAuthor", fields: [authorId], references: [id])
  comment   String   @db.Text
  createdAt DateTime @default(now())
}

// ---------- Production scheduling ----------

model Task {
  id             String     @id @default(cuid())
  jobId          String
  job            Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  taskNo         String     @unique
  name           String
  description    String?
  leadId         String?
  lead           User?      @relation("TaskLead", fields: [leadId], references: [id])
  status         TaskStatus @default(NOT_STARTED)
  estimatedHours Float      @default(0)
  startDate      DateTime
  endDate        DateTime
  version        Int        @default(1)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assignments TaskAssignment[]
  eodComments EodComment[]
  comments    JobComment[]
}

model TaskAssignment {
  id            String     @id @default(cuid())
  taskId        String
  task          Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  shift         ShiftCode
  date          DateTime
  hoursBooked   Float
  // Where this booking renders on the hour-column Live Job Timeline (Gantt) for `date`.
  // Null means "not yet positioned" — the UI falls back to the shift's start time.
  scheduledStart DateTime?
  // Live clocking state for this person's work on this task.
  workStatus    WorkStatus @default(NOT_STARTED)
  actualMinutes Int        @default(0)
  lastStartedAt DateTime?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())

  timeLogs TimeLog[]

  @@index([userId, date])
}

// Append-only audit trail of every Start/Hold/Query/Resume/Complete action, used to compute
// actual worked time and to render the job roadmap/timeline.
model TimeLog {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   TaskAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  action       TimeLogAction
  note         String?         @db.Text
  actorId      String
  actor        User            @relation("TimeLogActor", fields: [actorId], references: [id])
  createdAt    DateTime        @default(now())
}

model Shift {
  id        String    @id @default(cuid())
  code      ShiftCode @unique
  label     String
  startTime String
  endTime   String
  breakMins Int       @default(60)
  isDefault Boolean   @default(false)
}

model Leave {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("LeaveOwner", fields: [userId], references: [id])
  date         DateTime
  reason       String?
  markedById   String
  markedBy     User     @relation("LeaveMarkedBy", fields: [markedById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([userId, date])
}

// A user's break entries for a given day. Server enforces a 60-minute total cap per user/day.
model BreakLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  date      DateTime
  startAt   DateTime
  endAt     DateTime?
  minutes   Int
  createdAt DateTime  @default(now())

  @@index([userId, date])
}

model EodComment {
  id        String   @id @default(cuid())
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  comment   String   @db.Text
  createdAt DateTime @default(now())

  // One EOD note per person per day (optionally referencing a task for context).
  @@unique([userId, date])
}
